rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /flats/{flatId} {
      // Any authenticated user can read flat docs.
      // This is required so that unenrolled users can look up a flat by invite
      // code before they have been added as a member.
      allow read: if request.auth != null;
      // Only admin can write flat-level settings.
      allow write: if isAdmin(flatId);

      match /tasks/{taskId} {
        allow read: if isMember(flatId);
        allow write: if isMember(flatId);
      }

      match /members/{uid} {
        allow read: if isMember(flatId);
        // Members write only their own doc; admin can write any member doc.
        allow write: if request.auth.uid == uid || isAdmin(flatId);
      }

      match /issues/{issueId} {
        allow read, write: if isMember(flatId);
      }

      match /shoppingItems/{itemId} {
        allow read, write: if isMember(flatId);
      }

      match /swapRequests/{requestId} {
        allow read: if isMember(flatId);
        // Requester creates; either party can update (accept/decline).
        allow create: if isMember(flatId);
        allow update: if isMember(flatId);
        allow delete: if isAdmin(flatId);
      }
    }


    function isMember(flatId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
    }

    function isAdmin(flatId) {
      return isMember(flatId)
        && get(/databases/$(database)/documents/flats/$(flatId)).data.admin_uid == request.auth.uid;
    }
  }
}
